{
  "version": 2,
  "buildCommand": "npm install",
  "devCommand": "vercel dev",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "page/api/*.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/page/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
